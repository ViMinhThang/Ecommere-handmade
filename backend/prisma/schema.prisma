generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ROLE_USER
  ROLE_SELLER
  ROLE_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String     @id @default(uuid())
  name          String
  email         String     @unique
  password      String
  roles         Role[]     @default([ROLE_USER])
  status        UserStatus @default(ACTIVE)
  avatar        String?
  phone         String?
  shopName      String?
  otpCode       String?
  otpExpires    DateTime?
  isEmailVerified Boolean  @default(false)
  deletedAt     DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  addresses     Address[]
  sellerProducts Product[] @relation("Product_sellerId_fkey")
  folders       ImageFolder[]
  refreshTokens RefreshToken[]

  @@index([status])
}

model Address {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName  String
  phone     String
  address   String
  city      String
  district  String
  ward      String
  isDefault Boolean  @default(false)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id           String         @id @default(uuid())
  name         String         @unique
  description  String?
  image        String?
  productsCount Int           @default(0)
  status       CategoryStatus @default(ACTIVE)
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  products     Product[]
  vouchers     Voucher[]
  flashSaleCategories FlashSaleCategory[]

  @@index([status])
}

model Product {
  id               String        @id @default(uuid())
  name             String
  description      String
  price            Decimal       @default(0)
  categoryId       String
  category         Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  sellerId         String
  seller           User          @relation("Product_sellerId_fkey", fields: [sellerId], references: [id], onDelete: Cascade)
  status           ProductStatus @default(PENDING)
  stock            Int           @default(0)
  lowStockThreshold Int          @default(10)
  sku              String?
  descriptionImages String[]     @default([])
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  images           ProductImage[]
  inventoryLogs    InventoryLog[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([status])
}

model ProductImage {
  id        String   @id @default(uuid())
  url       String
  isMain    Boolean  @default(false)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  deletedAt DateTime?
  createdAt DateTime @default(now())

  @@index([productId])
}

model ImageFolder {
  id        String   @id @default(uuid())
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  images    Image[]

  @@index([userId])
}

model Image {
  id          String      @id @default(uuid())
  displayName String
  path        String
  folderId    String
  folder      ImageFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())

  @@index([folderId])
}

enum InventoryChangeReason {
  ORDER
  MANUAL
  RESTOCK
  RETURN
}

model InventoryLog {
  id        String               @id @default(uuid())
  productId String
  product   Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  change    Int
  reason    InventoryChangeReason
  deletedAt DateTime?
  createdAt DateTime             @default(now())
  @@index([productId])
}

model Voucher {
  id          String        @id @default(uuid())
  name        String
  description String?
  code        String        @unique
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  isActive    Boolean       @default(true)
  endDate     DateTime
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  ranges      VoucherRange[]

  @@index([categoryId])
}

model VoucherRange {
  id              String   @id @default(uuid())
  voucherId       String
  voucher         Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  minPrice        Decimal
  maxPrice        Decimal
  discountPercent Decimal
  endDate         DateTime
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([voucherId])
}

model FlashSale {
  id          String   @id @default(uuid())
  name        String
  description String?
  banner      String?
  startAt     DateTime
  endAt       DateTime
  isActive    Boolean  @default(true)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  categories  FlashSaleCategory[]
  ranges      FlashSaleRange[]

  @@index([isActive, startAt, endAt])
}

model FlashSaleCategory {
  id          String    @id @default(uuid())
  flashSaleId String
  flashSale   FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  deletedAt   DateTime?

  @@unique([flashSaleId, categoryId])
  @@index([flashSaleId])
  @@index([categoryId])
}

model FlashSaleRange {
  id              String    @id @default(uuid())
  flashSaleId     String
  flashSale       FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  minPrice        Decimal
  maxPrice        Decimal
  discountPercent Decimal
  endDate         DateTime
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([flashSaleId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  replacedByToken String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}
