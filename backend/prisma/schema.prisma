generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ROLE_USER
  ROLE_SELLER
  ROLE_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductQuestionStatus {
  PUBLISHED
  HIDDEN
  DELETED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  STRIPE
  COD
}

enum PaymentStatus {
  UNPAID
  PAID
  COD_PENDING
  FAILED
  PARTIALLY_REFUNDED
  REFUNDED
}

enum CustomOrderStatus {
  DRAFT
  PENDING_REVIEW
  REVISION_REQUESTED
  AWAITING_PAYMENT
  CRAFTING
  FINISHING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum MarketplaceLedgerEntryType {
  PAYMENT_CAPTURE
  SELLER_EARNING
  PLATFORM_FEE
  PLATFORM_DISCOUNT
  REFUND
  PAYOUT
}

enum MarketplaceLedgerEntryStatus {
  PENDING
  POSTED
  VOIDED
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum RewardPointLedgerType {
  EARN
  REDEEM
  REFUND
  ADJUSTMENT
  EXPIRE
}

enum ReportType {
  SHOP
  CUSTOMER
  PRODUCT
  ORDER
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  REJECTED
}

enum SellerPayoutStatus {
  PENDING
  PAID
  FAILED
}

enum NotificationType {
  ORDER_CREATED
  ORDER_STATUS_UPDATED
  ORDER_CANCELLED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  REFUND_UPDATED
  PRODUCT_SUBMITTED
  PRODUCT_APPROVED
  PRODUCT_REJECTED
  CHAT_MESSAGE
  CUSTOM_QUOTE_SENT
  CUSTOM_ORDER_CREATED
  CUSTOM_ORDER_STATUS_UPDATED
  REPORT_CREATED
  REPORT_STATUS_UPDATED
  REVIEW_CREATED
  REVIEW_REPLIED
  QUESTION_CREATED
  QUESTION_ANSWERED
  REWARD_POINTS_UPDATED
  SYSTEM
}

enum FlashSaleState {
  ACTIVE
  PAUSED
  ENDED
}

enum CommissionPostStatus {
  OPEN
  ASSIGNED
  CLOSED
  CANCELLED
}

enum CommissionProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model User {
  id                    String                      @id @default(uuid())
  name                  String
  email                 String                      @unique
  password              String
  roles                 Role[]                      @default([ROLE_USER])
  status                UserStatus                  @default(ACTIVE)
  avatar                String?
  phone                 String?
  shopName              String?
  sellerTitle           String?
  sellerBio             String?
  sellerAbout           String?
  sellerHeroImage       String?
  sellerAboutImage      String?
  sellerStat1Label      String?
  sellerStat1Value      String?
  sellerStat2Label      String?
  sellerStat2Value      String?
  artisanVerified       Boolean                     @default(false)
  craftSpecialty        String?
  craftExperienceYears  Int?
  craftMaterials        String[]                    @default([])
  verificationNote      String?
  otpCode               String?
  otpExpires            DateTime?
  isEmailVerified       Boolean                     @default(false)
  rewardPointsBalance   Int                         @default(0)
  deletedAt             DateTime?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  addresses             Address[]
  sellerProducts        Product[]                   @relation("Product_sellerId_fkey")
  folders               ImageFolder[]
  refreshTokens         RefreshToken[]
  cart                  Cart?
  customerConversations ChatConversation[]          @relation("ChatConversationCustomer")
  sellerConversations   ChatConversation[]          @relation("ChatConversationSeller")
  sentChatMessages      ChatMessage[]               @relation("ChatMessageSender")
  chatReadStates        ChatConversationReadState[] @relation("ChatConversationReadUser")
  Order                 Order[]
  SubOrder              SubOrder[]
  customerCustomOrders  CustomOrder[]               @relation("CustomerCustomOrders")
  sellerCustomOrders    CustomOrder[]               @relation("SellerCustomOrders")
  quoteTemplates        CustomOrderQuoteTemplate[]  @relation("SellerQuoteTemplates")
  reviews               Review[]
  productQuestions      ProductQuestion[]           @relation("ProductQuestionUser")
  answeredQuestions     ProductQuestion[]           @relation("ProductQuestionAnsweredBy")
  wishlistItems         WishlistItem[]
  followedShops         ShopFollow[]                @relation("ShopFollowCustomer")
  shopFollowers         ShopFollow[]                @relation("ShopFollowSeller")
  shopReviewsWritten    ShopReview[]                @relation("ShopReviewsWritten")
  shopReviewsReceived   ShopReview[]                @relation("ShopReviewsReceived")
  customerLedgerEntries MarketplaceLedgerEntry[]    @relation("LedgerEntryCustomer")
  sellerLedgerEntries   MarketplaceLedgerEntry[]    @relation("LedgerEntrySeller")
  rewardPointLedger     RewardPointLedger[]         @relation("RewardPointLedgerUser")
  reportsFiled          Report[]                    @relation("ReportReporter")
  reportsTargetingUser  Report[]                    @relation("ReportTargetUser")
  reportsResolved       Report[]                    @relation("ReportResolvedBy")
  sellerPayouts         SellerPayout[]              @relation("SellerPayoutSeller")
  sellerVouchers        Voucher[]                   @relation("SellerVouchers")
  voucherUsages         VoucherUsage[]              @relation("UserVoucherUsages")
  flashSaleUsages       FlashSaleUserUsage[]
  commissionPosts       CommissionPost[]            @relation("CommissionPostCustomer")
  commissionProposals   CommissionProposal[]        @relation("CommissionProposalSeller")
  notifications         Notification[]              @relation("UserNotifications")
  customOrderProgress   CustomOrderProgressEvent[]  @relation("CustomOrderProgressActor")

  @@index([status])
}

model PlatformSetting {
  id                  String   @id @default("platform")
  platformName        String   @default("HandCraft Market")
  platformDescription String   @default("Marketplace for handmade products")
  commissionBps       Int      @default(1000)
  updatedById         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Address {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName  String
  phone     String
  address   String
  city      String
  district  String
  ward      String
  isDefault Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Category {
  id                  String              @id @default(uuid())
  name                String              @unique
  description         String?
  image               String?
  slug                String?             @unique
  productsCount       Int                 @default(0)
  status              CategoryStatus      @default(ACTIVE)
  deletedAt           DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  products            Product[]
  vouchers            Voucher[]
  flashSaleCategories FlashSaleCategory[]

  @@index([status])
}

model Product {
  id                          String                    @id @default(uuid())
  name                        String
  description                 String
  price                       Decimal                   @default(0)
  categoryId                  String
  category                    Category                  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  sellerId                    String
  seller                      User                      @relation("Product_sellerId_fkey", fields: [sellerId], references: [id], onDelete: Cascade)
  status                      ProductStatus             @default(PENDING)
  stock                       Int                       @default(0)
  lowStockThreshold           Int                       @default(10)
  sku                         String?
  tags                        String[]                  @default([])
  descriptionImages           String[]                  @default([])
  personalizationEnabled      Boolean                   @default(false)
  personalizationRequired     Boolean                   @default(false)
  personalizationInstructions String?                   @db.Text
  personalizationMaxLength    Int                       @default(120)
  viewCount                   Int                       @default(0)
  deletedAt                   DateTime?
  createdAt                   DateTime                  @default(now())
  updatedAt                   DateTime                  @updatedAt
  images                      ProductImage[]
  inventoryLogs               InventoryLog[]
  cartItems                   CartItem[]
  chatContextConversations    ChatConversation[]
  OrderItem                   OrderItem[]
  reviews                     Review[]
  questions                   ProductQuestion[]
  wishlistItems               WishlistItem[]
  homepageFeaturedProducts    HomepageFeaturedProduct[]
  flashSaleProducts           FlashSaleProduct[]
  reports                     Report[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([status])
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([userId, createdAt])
  @@index([productId])
}

model ShopFollow {
  id         String   @id @default(uuid())
  customerId String
  sellerId   String
  customer   User     @relation("ShopFollowCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  seller     User     @relation("ShopFollowSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([customerId, sellerId])
  @@index([customerId, createdAt])
  @@index([sellerId, createdAt])
}

model ShopReview {
  id         String   @id @default(uuid())
  sellerId   String
  seller     User     @relation("ShopReviewsReceived", fields: [sellerId], references: [id], onDelete: Cascade)
  customerId String
  customer   User     @relation("ShopReviewsWritten", fields: [customerId], references: [id], onDelete: Cascade)
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([customerId, sellerId])
  @@index([sellerId, createdAt])
  @@index([sellerId, rating])
  @@index([customerId, createdAt])
}

model HomepageBanner {
  id        String    @id @default(uuid())
  title     String
  subtitle  String?
  imageUrl  String
  linkUrl   String?
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  startAt   DateTime?
  endAt     DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([isActive, sortOrder])
  @@index([startAt])
  @@index([endAt])
}

model HomepageFeaturedProduct {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId])
  @@index([isActive, sortOrder])
}

enum ChatMessageType {
  TEXT
  IMAGE
  CUSTOM_ORDER_OFFER
}

model ChatConversation {
  id               String                      @id @default(uuid())
  customerId       String
  sellerId         String
  contextProductId String?
  customer         User                        @relation("ChatConversationCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  seller           User                        @relation("ChatConversationSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  contextProduct   Product?                    @relation(fields: [contextProductId], references: [id], onDelete: SetNull)
  messages         ChatMessage[]
  readStates       ChatConversationReadState[]
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  @@unique([customerId, sellerId])
  @@index([customerId])
  @@index([sellerId])
  @@index([updatedAt])
}

model ChatMessage {
  id             String           @id @default(uuid())
  conversationId String
  senderId       String
  type           ChatMessageType
  payload        Json
  createdAt      DateTime         @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User             @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model ChatConversationReadState {
  id             String           @id @default(uuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User             @relation("ChatConversationReadUser", fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([conversationId, userId])
  @@index([userId])
}

model ProductImage {
  id        String    @id @default(uuid())
  url       String
  isMain    Boolean   @default(false)
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([productId])
}

model ImageFolder {
  id        String    @id @default(uuid())
  name      String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  images    Image[]

  @@index([userId])
}

model Image {
  id          String      @id @default(uuid())
  displayName String
  path        String
  folderId    String
  folder      ImageFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())

  @@index([folderId])
}

enum InventoryChangeReason {
  ORDER
  MANUAL
  RESTOCK
  RETURN
}

model InventoryLog {
  id        String                @id @default(uuid())
  productId String
  product   Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  change    Int
  reason    InventoryChangeReason
  deletedAt DateTime?
  createdAt DateTime              @default(now())

  @@index([productId])
}

model Voucher {
  id                String         @id @default(uuid())
  name              String
  description       String?
  code              String         @unique
  categoryId        String
  category          Category       @relation(fields: [categoryId], references: [id])
  sellerId          String?
  seller            User?          @relation("SellerVouchers", fields: [sellerId], references: [id], onDelete: SetNull)
  isActive          Boolean        @default(true)
  endDate           DateTime
  maxDiscountAmount Decimal?
  usageLimit        Int?
  perUserLimit      Int?
  usedCount         Int            @default(0)
  deletedAt         DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  ranges            VoucherRange[]
  carts             Cart[]
  usages            VoucherUsage[]

  @@index([categoryId])
  @@index([sellerId, isActive, endDate])
  @@index([isActive, endDate])
}

model VoucherRange {
  id              String    @id @default(uuid())
  voucherId       String
  voucher         Voucher   @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  minPrice        Decimal
  maxPrice        Decimal
  discountPercent Decimal
  endDate         DateTime
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([voucherId])
}

model VoucherUsage {
  id        String   @id @default(uuid())
  voucherId String
  voucher   Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("UserVoucherUsages", fields: [userId], references: [id], onDelete: Cascade)
  orderId   String?  @unique
  order     Order?   @relation("OrderVoucherUsage", fields: [orderId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([voucherId, createdAt])
  @@index([userId, createdAt])
}

model FlashSale {
  id                 String               @id @default(uuid())
  name               String
  description        String?
  banner             String?
  startAt            DateTime
  endAt              DateTime
  isActive           Boolean              @default(true)
  saleState          FlashSaleState       @default(ACTIVE)
  pausedReason       String?
  pausedAt           DateTime?
  maxUnits           Int?
  perUserLimit       Int?
  reserveStock       Int                  @default(0)
  autoPauseThreshold Int?
  soldUnits          Int                  @default(0)
  reservedUnits      Int                  @default(0)
  deletedAt          DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  categories         FlashSaleCategory[]
  products           FlashSaleProduct[]
  ranges             FlashSaleRange[]
  userUsages         FlashSaleUserUsage[]

  @@index([isActive, saleState, startAt, endAt])
  @@index([isActive, startAt, endAt])
}

model FlashSaleCategory {
  id          String    @id @default(uuid())
  flashSaleId String
  flashSale   FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  deletedAt   DateTime?

  @@unique([flashSaleId, categoryId])
  @@index([flashSaleId])
  @@index([categoryId])
}

model FlashSaleProduct {
  id          String    @id @default(uuid())
  flashSaleId String
  flashSale   FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  deletedAt   DateTime?

  @@unique([flashSaleId, productId])
  @@index([flashSaleId])
  @@index([productId])
}

model FlashSaleRange {
  id              String    @id @default(uuid())
  flashSaleId     String
  flashSale       FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  minPrice        Decimal
  maxPrice        Decimal
  discountPercent Decimal
  endDate         DateTime
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([flashSaleId])
}

model FlashSaleUserUsage {
  id            String    @id @default(uuid())
  flashSaleId   String
  flashSale     FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  soldUnits     Int       @default(0)
  reservedUnits Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([flashSaleId, userId])
  @@index([userId])
}

model RefreshToken {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token           String   @unique
  expiresAt       DateTime
  revoked         Boolean  @default(false)
  replacedByToken String?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model Cart {
  id               String     @id @default(uuid())
  userId           String     @unique
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  appliedVoucherId String?
  appliedVoucher   Voucher?   @relation(fields: [appliedVoucherId], references: [id], onDelete: SetNull)
  items            CartItem[]
  deletedAt        DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model CartItem {
  id              String   @id @default(uuid())
  cartId          String
  cart            Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity        Int      @default(1)
  personalization Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

model Order {
  id                     String                   @id @default(uuid())
  customerId             String
  customer               User                     @relation(fields: [customerId], references: [id])
  totalAmount            Decimal
  discountAmount         Decimal                  @default(0)
  rewardPointsRedeemed   Int                      @default(0)
  rewardDiscountAmount   Decimal                  @default(0)
  voucherCode            String?
  status                 OrderStatus              @default(PENDING)
  paymentMethod          PaymentMethod            @default(STRIPE)
  paymentStatus          PaymentStatus            @default(UNPAID)
  paymentIntentId        String?                  @unique
  paymentExpiresAt       DateTime?
  checkoutIdempotencyKey String?
  currency               String                   @default("vnd")
  shippingAddress        Json?
  giftWrap               Boolean                  @default(false)
  giftCard               Boolean                  @default(false)
  giftMessage            String?                  @db.Text
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  subOrders              SubOrder[]
  ledgerEntries          MarketplaceLedgerEntry[]
  rewardPointLedger      RewardPointLedger[]
  refunds                Refund[]
  reports                Report[]
  voucherUsage           VoucherUsage?            @relation("OrderVoucherUsage")

  @@unique([customerId, checkoutIdempotencyKey])
  @@index([customerId])
}

model SubOrder {
  id             String                   @id @default(uuid())
  orderId        String
  order          Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sellerId       String
  seller         User                     @relation(fields: [sellerId], references: [id])
  subTotal       Decimal
  discountAmount Decimal                  @default(0)
  status         OrderStatus              @default(PENDING)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  items          OrderItem[]
  ledgerEntries  MarketplaceLedgerEntry[]
  refunds        Refund[]

  @@index([orderId])
  @@index([sellerId])
}

model OrderItem {
  id                       String   @id @default(uuid())
  subOrderId               String
  subOrder                 SubOrder @relation(fields: [subOrderId], references: [id], onDelete: Cascade)
  productId                String
  product                  Product  @relation(fields: [productId], references: [id])
  quantity                 Int
  price                    Decimal
  originalPrice            Decimal  @default(0)
  platformDiscountAmount   Decimal  @default(0)
  flashSaleId              String?
  flashSaleDiscountPercent Decimal?
  personalization          Json?

  review Review?

  @@index([subOrderId])
  @@index([productId])
  @@index([flashSaleId])
}

model Review {
  id          String   @id @default(uuid())
  rating      Int      @default(5)
  comment     String?  @db.Text
  images      String[] @default([])
  sellerReply String?  @db.Text

  userId String
  user   User   @relation(fields: [userId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  orderItemId String    @unique
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([userId])
}

model ProductQuestion {
  id           String                @id @default(uuid())
  productId    String
  userId       String
  question     String                @db.Text
  answer       String?               @db.Text
  answeredAt   DateTime?
  answeredById String?
  status       ProductQuestionStatus @default(PUBLISHED)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  product      Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  user         User                  @relation("ProductQuestionUser", fields: [userId], references: [id], onDelete: Cascade)
  answeredBy   User?                 @relation("ProductQuestionAnsweredBy", fields: [answeredById], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([userId])
  @@index([answeredById])
  @@index([status])
  @@index([createdAt])
}

model CustomOrderQuoteTemplate {
  id                String        @id @default(uuid())
  sellerId          String
  seller            User          @relation("SellerQuoteTemplates", fields: [sellerId], references: [id], onDelete: Cascade)
  name              String
  title             String
  description       String        @db.Text
  estimatedPrice    Decimal?
  minPrice          Decimal?
  maxPrice          Decimal?
  materials         Json          @default("[]")
  sizeOptions       Json          @default("[]")
  estimatedLeadTime String?
  revisionPolicy    String?       @db.Text
  shippingNote      String?       @db.Text
  termsNote         String?       @db.Text
  isActive          Boolean       @default(true)
  deletedAt         DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  customOrders      CustomOrder[]

  @@index([sellerId, isActive, updatedAt])
  @@index([sellerId, deletedAt])
}

model CustomOrder {
  id               String                    @id @default(uuid())
  customerId       String
  customer         User                      @relation("CustomerCustomOrders", fields: [customerId], references: [id])
  sellerId         String
  seller           User                      @relation("SellerCustomOrders", fields: [sellerId], references: [id])
  paymentIntentId  String?                   @unique
  paymentStatus    PaymentStatus             @default(UNPAID)
  paymentExpiresAt DateTime?
  quoteTemplateId  String?
  quoteTemplate    CustomOrderQuoteTemplate? @relation(fields: [quoteTemplateId], references: [id], onDelete: SetNull)
  quoteSnapshot    Json?
  quoteSentAt      DateTime?
  quoteAcceptedAt  DateTime?

  title          String
  artisanNote    String? @db.Text
  price          Decimal
  leadTime       String?
  specifications Json?   @default("[]")
  sketchImageUrl String?
  revisionNote   String? @db.Text

  status CustomOrderStatus @default(DRAFT)

  cancelledAt    DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  ledgerEntries  MarketplaceLedgerEntry[]
  refunds        Refund[]
  progressEvents CustomOrderProgressEvent[]

  @@index([customerId])
  @@index([sellerId])
  @@index([paymentIntentId])
  @@index([quoteTemplateId])
}

model CustomOrderProgressEvent {
  id            String             @id @default(uuid())
  customOrderId String
  customOrder   CustomOrder        @relation(fields: [customOrderId], references: [id], onDelete: Cascade)
  actorId       String
  actor         User               @relation("CustomOrderProgressActor", fields: [actorId], references: [id], onDelete: Cascade)
  status        CustomOrderStatus?
  title         String
  note          String?            @db.Text
  imageUrl      String?
  createdAt     DateTime           @default(now())

  @@index([customOrderId, createdAt])
  @@index([actorId, createdAt])
  @@index([status, createdAt])
}

model CommissionPost {
  id                 String               @id @default(uuid())
  customerId         String
  customer           User                 @relation("CommissionPostCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  selectedProposalId String?              @unique
  selectedProposal   CommissionProposal?  @relation("SelectedCommissionProposal", fields: [selectedProposalId], references: [id], onDelete: SetNull)
  customOrderId      String?
  title              String
  description        String               @db.Text
  budgetMin          Decimal?
  budgetMax          Decimal?
  desiredTimeline    String?
  referenceImages    String[]             @default([])
  status             CommissionPostStatus @default(OPEN)
  closedAt           DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  proposals          CommissionProposal[] @relation("CommissionPostProposals")

  @@index([customerId, createdAt])
  @@index([status, createdAt])
}

model CommissionProposal {
  id               String                   @id @default(uuid())
  commissionId     String
  commission       CommissionPost           @relation("CommissionPostProposals", fields: [commissionId], references: [id], onDelete: Cascade)
  sellerId         String
  seller           User                     @relation("CommissionProposalSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  selectedFor      CommissionPost?          @relation("SelectedCommissionProposal")
  message          String                   @db.Text
  proposedPrice    Decimal
  proposedLeadTime String
  sketchImageUrl   String?
  status           CommissionProposalStatus @default(PENDING)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@unique([commissionId, sellerId])
  @@index([sellerId, createdAt])
  @@index([commissionId, status])
}

model PaymentWebhookEvent {
  id              String   @id @default(uuid())
  eventId         String   @unique
  type            String
  paymentIntentId String?
  processedAt     DateTime @default(now())

  @@index([paymentIntentId])
}

model MarketplaceLedgerEntry {
  id             String                       @id @default(uuid())
  type           MarketplaceLedgerEntryType
  status         MarketplaceLedgerEntryStatus @default(POSTED)
  amount         Decimal
  currency       String                       @default("vnd")
  idempotencyKey String                       @unique
  orderId        String?
  subOrderId     String?
  customOrderId  String?
  refundId       String?
  sellerId       String?
  customerId     String?
  metadata       Json?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  order          Order?                       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  subOrder       SubOrder?                    @relation(fields: [subOrderId], references: [id], onDelete: Cascade)
  customOrder    CustomOrder?                 @relation(fields: [customOrderId], references: [id], onDelete: Cascade)
  refund         Refund?                      @relation(fields: [refundId], references: [id], onDelete: SetNull)
  seller         User?                        @relation("LedgerEntrySeller", fields: [sellerId], references: [id], onDelete: SetNull)
  customer       User?                        @relation("LedgerEntryCustomer", fields: [customerId], references: [id], onDelete: SetNull)

  @@index([sellerId, createdAt])
  @@index([customerId, createdAt])
  @@index([orderId])
  @@index([subOrderId])
  @@index([customOrderId])
  @@index([refundId])
  @@index([type, status])
}

model RewardPointLedger {
  id             String                @id @default(uuid())
  userId         String
  orderId        String?
  type           RewardPointLedgerType
  points         Int
  balanceAfter   Int
  description    String?
  idempotencyKey String                @unique
  createdAt      DateTime              @default(now())
  user           User                  @relation("RewardPointLedgerUser", fields: [userId], references: [id], onDelete: Cascade)
  order          Order?                @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([orderId])
  @@index([type])
}

model Report {
  id              String       @id @default(uuid())
  reporterId      String
  targetUserId    String?
  targetProductId String?
  orderId         String?
  type            ReportType
  reason          String
  description     String?      @db.Text
  status          ReportStatus @default(PENDING)
  adminNote       String?      @db.Text
  resolvedById    String?
  resolvedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  reporter        User         @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  targetUser      User?        @relation("ReportTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetProduct   Product?     @relation(fields: [targetProductId], references: [id], onDelete: SetNull)
  order           Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  resolvedBy      User?        @relation("ReportResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([reporterId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([targetProductId])
  @@index([orderId])
  @@index([status, createdAt])
  @@index([type])
}

model Refund {
  id               String                   @id @default(uuid())
  orderId          String?
  subOrderId       String?
  customOrderId    String?
  paymentIntentId  String
  providerRefundId String?
  amount           Decimal
  currency         String                   @default("vnd")
  reason           String
  status           RefundStatus             @default(PENDING)
  idempotencyKey   String                   @unique
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  order            Order?                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  subOrder         SubOrder?                @relation(fields: [subOrderId], references: [id], onDelete: SetNull)
  customOrder      CustomOrder?             @relation(fields: [customOrderId], references: [id], onDelete: Cascade)
  ledgerEntries    MarketplaceLedgerEntry[]

  @@index([orderId])
  @@index([subOrderId])
  @@index([customOrderId])
  @@index([paymentIntentId])
  @@index([status])
}

model SellerPayout {
  id             String             @id @default(uuid())
  sellerId       String
  seller         User               @relation("SellerPayoutSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  amount         Decimal
  currency       String             @default("vnd")
  status         SellerPayoutStatus @default(PENDING)
  idempotencyKey String             @unique
  providerRef    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([sellerId, createdAt])
  @@index([status])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String           @db.Text
  link      String?
  metadata  Json?
  dedupeKey String?
  readAt    DateTime?
  deletedAt DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, dedupeKey])
  @@index([userId, readAt, createdAt])
  @@index([userId, createdAt])
  @@index([type, createdAt])
}
