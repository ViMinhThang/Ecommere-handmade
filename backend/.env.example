# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ecommerce_handmade?schema=public"

# JWT
JWT_SECRET="replace-with-local-jwt-secret"
JWT_EXPIRES_IN="7d"
GOOGLE_CLIENT_ID="replace-with-google-web-client-id.apps.googleusercontent.com"

# Bcrypt
BCRYPT_ROUNDS=12

# App
PORT=3001
FRONTEND_URL="http://localhost:3000"
ENABLE_SWAGGER=true
PLATFORM_NAME="HandCraft Market"
PLATFORM_DESCRIPTION="Marketplace for handmade products"
PLATFORM_COMMISSION_BPS=1000
SEED_ADMIN_EMAIL="admin@ecommerce.com"
SEED_ADMIN_PASSWORD="replace-with-strong-local-admin-password"

# SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="dummy@gmail.com"
SMTP_PASS="dummy"
SMTP_FROM="platform-ecom@no-reply.com"

# Stripe
STRIPE_SECRET_KEY="sk_test_REPLACE_WITH_REAL_TEST_SECRET_KEY"
STRIPE_WEBHOOK_SECRET="whsec_REPLACE_WITH_REAL_WEBHOOK_SECRET"

# Auto import products from local product.csv when backend starts
AUTO_IMPORT_PRODUCTS_ON_BOOT=true
AUTO_IMPORT_PRODUCTS_RESET_ON_BOOT=true
AUTO_IMPORT_PRODUCTS_ONLY_IF_EMPTY=false
AUTO_IMPORT_PRODUCTS_LIMIT=100
PRODUCT_IMPORT_SOURCE_FILE="crawl/data/product.csv"
EBAY_IMPORT_QUERY="handmade pottery ceramic"
EBAY_MARKETPLACE_ID="EBAY_US"
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
