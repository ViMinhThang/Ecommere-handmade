# Database
DATABASE_URL="postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:5432/ecommerce_handmade?schema=public"

# JWT
JWT_SECRET="replace-with-long-random-jwt-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
GOOGLE_CLIENT_ID="your-google-web-client-id.apps.googleusercontent.com"

# Bcrypt
BCRYPT_ROUNDS=12

# App
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:3000"
ENABLE_SWAGGER=true
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=300
PLATFORM_NAME="HandCraft Market"
PLATFORM_DESCRIPTION="Marketplace for handmade products"
PLATFORM_COMMISSION_BPS=1000
FLASH_SALE_GUARDRAILS_ENABLED=false

# SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="dummy@gmail.com"
SMTP_PASS="your-smtp-app-password"
SMTP_FROM="platform-ecom@no-reply.com"

# Stripe
# Must be from the same Stripe account and mode as frontend NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY.
STRIPE_SECRET_KEY="sk_test_REPLACE_WITH_REAL_TEST_SECRET_KEY"
STRIPE_WEBHOOK_SECRET="whsec_REPLACE_WITH_REAL_WEBHOOK_SECRET"

# Local seed admin (non-production). Set password explicitly; no default password is provided.
SEED_ADMIN_EMAIL="admin@ecommerce.com"
SEED_ADMIN_PASSWORD="replace-with-strong-local-admin-password"

# Auto import products from local source file (CSV/XLSX/JSON) when backend starts
AUTO_IMPORT_PRODUCTS_ON_BOOT=true
AUTO_IMPORT_PRODUCTS_RESET_ON_BOOT=false
AUTO_IMPORT_PRODUCTS_ONLY_IF_EMPTY=true
AUTO_IMPORT_PRODUCTS_LIMIT=100
PRODUCT_IMPORT_SOURCE_FILE="crawl/data/ebay-products-raw.json"
EBAY_IMPORT_SOURCE_FILE="crawl/data/ebay-products-raw.json"
EBAY_IMPORT_QUERY="handmade pottery ceramic"
EBAY_MARKETPLACE_ID="EBAY_US"
EBAY_CLIENT_ID="your-ebay-client-id"
EBAY_CLIENT_SECRET="your-ebay-client-secret"
